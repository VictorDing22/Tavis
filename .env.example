# Resend 邮件服务 API Key
# 注册地址: https://resend.com → API Keys → Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 接收联系表单邮件的邮箱地址
CONTACT_EMAIL=your-email@example.com
